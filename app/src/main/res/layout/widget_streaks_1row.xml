        </LinearLayout>
    </FrameLayout>
    <FrameLayout android:id="@+id/streak_column_6" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
        <LinearLayout android:id="@+id/streak_inner_6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_horizontal" android:orientation="vertical" android:gravity="center_horizontal" android:paddingLeft="4dp" android:paddingRight="4dp">
