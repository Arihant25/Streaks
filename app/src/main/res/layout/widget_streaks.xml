                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="bottom|end"
                    android:src="@drawable/ic_widget_check"
                    android:visibility="gone"
                    android:contentDescription="@string/mark_completed" />
            </FrameLayout>
            <TextView
