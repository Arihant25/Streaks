<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Streaks" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color (replaced by dynamic color on supported devices). -->
        <item name="colorPrimary">@color/orange_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/orange</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar blends with the app background ("white" resolves dark at night). -->
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
