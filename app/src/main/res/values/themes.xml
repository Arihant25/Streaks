<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Streaks" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/orange_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- System bars are transparent (edge-to-edge); statusBarColor and
             navigationBarColor are deprecated as of Android 15 -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Match the screen background so fragment transitions never flash -->
        <item name="android:windowBackground">@color/screen_background</item>
        <!-- Customize your theme here. -->
    </style>

</resources>